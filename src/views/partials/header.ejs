<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sociali</title>
    <style>
        :root {
            --primary: #1da1f2;
            --primary-hover: #1991db;
            --secondary: #14171a;
            --bg: #f5f8fa;
            --white: #ffffff;
            --border: #e1e8ed;
            --text: #14171a;
            --text-muted: #657786;
            --tag-bg: #e8f5fe;
            --tag-text: #1da1f2;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            padding: 0;
        }

        header {
            background-color: var(--white);
            border-bottom: 1px solid var(--border);
            padding: 10px 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        nav {
            max-width: 1000px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--primary);
            text-decoration: none;
            display: flex;
            align-items: center;
        }

        .nav-links {
            display: flex;
            align-items: center;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text);
            margin-left: 20px;
            font-weight: 600;
        }

        .search-container {
            flex-grow: 1;
            margin: 0 40px;
            max-width: 400px;
        }

        .search-container input {
            width: 100%;
            padding: 8px 15px;
            border: 1px solid var(--border);
            border-radius: 20px;
            background-color: #ebeef0;
            outline: none;
        }

        .search-container input:focus {
            background-color: var(--white);
            border-color: var(--primary);
        }

        .main-layout {
            max-width: 1000px;
            margin: 20px auto;
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
            padding: 0 20px;
        }

        @media (max-width: 768px) {
            .main-layout {
                grid-template-columns: 1fr;
            }
            .search-container {
                display: none;
            }
        }

        .card {
            background-color: var(--white);
            border: 1px solid var(--border);
            border-radius: 15px;
            padding: 15px;
            margin-bottom: 15px;
            transition: background-color 0.2s;
        }

        .card-link {
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .card-link:hover {
            background-color: #f7f9f9;
        }

        .btn {
            background-color: var(--primary);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: bold;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            font-size: 0.9rem;
        }

        .btn-outline {
            background-color: transparent;
            color: var(--primary);
            border: 1px solid var(--primary);
        }

        .btn:hover {
            background-color: var(--primary-hover);
        }

        .post-header {
            display: flex;
            align-items: center;
            margin-bottom: 8px;
        }

        .post-title {
            font-size: 1.2rem;
            font-weight: bold;
            margin: 0 0 10px 0;
        }

        .post-author {
            font-weight: bold;
            margin-right: 5px;
        }

        .post-date {
            color: var(--text-muted);
            font-size: 0.85rem;
        }

        .post-content {
            margin-bottom: 12px;
            line-height: 1.5;
            word-wrap: break-word;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 12px;
        }

        .tag {
            background-color: var(--tag-bg);
            color: var(--tag-text);
            padding: 2px 10px;
            border-radius: 12px;
            font-size: 0.8rem;
            text-decoration: none;
            font-weight: 500;
        }

        .tag:hover {
            background-color: #d0e9fc;
        }

        .post-actions {
            display: flex;
            color: var(--text-muted);
            font-size: 0.9rem;
            border-top: 1px solid var(--border);
            padding-top: 10px;
        }

        .post-actions span {
            margin-right: 25px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .pagination {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 20px;
            margin-bottom: 40px;
        }

        .page-link {
            padding: 8px 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            text-decoration: none;
            color: var(--text);
            background-color: var(--white);
        }

        .page-link.active {
            background-color: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .sidebar-title {
            font-weight: 800;
            font-size: 1.2rem;
            margin-bottom: 15px;
        }

        .sidebar-item {
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-item:last-child {
            border-bottom: none;
        }

        .sort-options {
            display: flex;
            gap: 15px;
            margin-bottom: 15px;
            font-size: 0.9rem;
        }

        .sort-options a {
            text-decoration: none;
            color: var(--text-muted);
        }

        .sort-options a.active {
            color: var(--primary);
            font-weight: bold;
            border-bottom: 2px solid var(--primary);
        }
    </style>
</head>
<body>
    <header>
        <nav>
            <a href="/" class="logo">Sociali</a>
            
            <form action="/" method="GET" class="search-container">
                <input type="text" name="search" placeholder="Search posts, tags..." value="<%= typeof query !== 'undefined' ? query.search || '' : '' %>">
            </form>

            <div class="nav-links">
                <a href="/">Feed</a>
                <a href="/login">Login</a>
                <a href="/register" class="btn">Sign Up</a>
            </div>
        </nav>
    </header>
    <div class="main-layout">
        <main>
